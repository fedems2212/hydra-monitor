      { k:'tele/flush_valve',   label:'Válvula flush',  type:'digital' },
    ]
  },
  {
    key: 'proceso', label: 'Proceso / Caudales',
    vars: [
      { k:'tele/flow_perm_lpm',  label:'Caudal permeado',  type:'analog', unit:'L/min', chart:true },
      { k:'tele/flow_rej_lpm',   label:'Caudal rechazo',   type:'analog', unit:'L/min', chart:true },
      { k:'tele/flow_feed_lpm',  label:'Caudal entrada',   type:'analog', unit:'L/min', chart:true },
      { k:'tele/total_liters',   label:'Total litros',     type:'analog', unit:'L',     chart:true },
      { k:'tele/total_m3',       label:'Total m³',         type:'analog', unit:'m³',   chart:true },
      { k:'tele/recovery_pct',   label:'Recuperación',     type:'analog', unit:'%',     chart:true },
    ]
  },
  {
    key: 'presiones', label: 'Presiones',
    vars: [
      { k:'tele/p_feed_bar',       label:'P. entrada',    type:'analog', unit:'bar', chart:true },
      { k:'tele/p_high_bar',       label:'P. alta',       type:'analog', unit:'bar', chart:true },
      { k:'tele/p_perm_bar',       label:'P. permeado',   type:'analog', unit:'bar', chart:true },
      { k:'tele/dp_prefilter_bar', label:'ΔP prefiltro',  type:'analog', unit:'bar', chart:true },
      { k:'tele/dp_membrane_bar',  label:'ΔP membrana',   type:'analog', unit:'bar', chart:true },
    ]
  },
  {
    key: 'calidad', label: 'Calidad del agua',
    vars: [
      { k:'tele/cond_feed_us',   label:'Cond. entrada',     type:'analog', unit:'µS/cm', chart:true },
      { k:'tele/cond_perm_us',   label:'Cond. permeado',    type:'analog', unit:'µS/cm', chart:true },
      { k:'tele/tds_feed_ppm',   label:'TDS entrada',       type:'analog', unit:'ppm',   chart:true },
      { k:'tele/tds_perm_ppm',   label:'TDS permeado',      type:'analog', unit:'ppm',   chart:true },
      { k:'tele/temp_c',         label:'Temperatura',       type:'analog', unit:'°C',    chart:true },
      { k:'tele/ph',             label:'pH',                type:'analog', unit:'',      chart:true },
      { k:'tele/orp_mv',         label:'ORP',               type:'analog', unit:'mV',    chart:true },
    ]
  },
  {
    key: 'contadores', label: 'Contadores',
    vars: [
      { k:'tele/pump_hours_low',          label:'Hrs bomba baja',      type:'analog', unit:'h', chart:true },
      { k:'tele/pump_hours_high',         label:'Hrs bomba alta',      type:'analog', unit:'h', chart:true },
      { k:'tele/starts_count',            label:'Arranques',           type:'analog', unit:'',  chart:true },
      { k:'tele/flush_count',             label:'Flushes',             type:'analog', unit:'',  chart:true },
      { k:'tele/service_hours_remaining', label:'Servicio restante',   type:'analog', unit:'h', chart:true },
    ]
  },
];

// Flat LABELS map for quick lookup (used by other parts of the code)
const LABELS = {};
SECTIONS.forEach(sec => {
  sec.vars.forEach(v => {
    LABELS[v.k] = { ...v, group: sec.key };
  });
});

const ALARM_LABELS = {
  'offline':          'Sin comunicación',
  'low_pressure':     'Presión baja',
  'high_pressure':    'Presión alta',
  'no_water_cistern': 'Sin agua cisterna',
  'no_water':         'Sin agua',
  'low_flow':         'Caudal bajo',
  'no_flow':          'Sin caudal',
  'leak':             'Pérdida detectada',
  'service_due':      'Servicio requerido',
  'membrane_fouling': 'Membrana sucia',
};

// Alarm labels

// CHART COLORS per variable
const CHART_COLORS = {
  'tele/flow_perm_lpm':  '#00d4ff', 'tele/flow_rej_lpm': '#7c4dff', 'tele/flow_feed_lpm': '#00b0ff',
  'tele/cond_perm_us':   '#ff6d00', 'tele/cond_feed_us': '#ff9100',
  'tele/p_feed_bar':     '#00e676', 'tele/p_high_bar':   '#69f0ae', 'tele/p_perm_bar': '#b9f6ca',
  'tele/dp_membrane_bar':'#ff3d57', 'tele/dp_prefilter_bar':'#ff6090',
  'tele/temp_c':         '#ffd740', 'tele/recovery_pct': '#b388ff',
  'tele/tds_perm_ppm':   '#ffab40', 'tele/tds_feed_ppm': '#ffd180',
};

// ═══════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════
let mqtt = null;
let devices = {};        // "ns/client/device" → DeviceData
let loginCfg = null;
let activeNav = 'clients';
let currentClientFilter = null;  // for screenDevices
let currentDevKey = null;        // for screenDashboard
let loginMode = 'client';        // 'client' | 'tech'
let charts = {};                 // devKey+varKey → Chart instance
const HISTORY_MAX = 1080;        // ~3h at 10s intervals

function makeDevice(ns, client, device) {
  return {
    ns, client, device,
    last: {}, alarms: {},
    aiState: null, aiReport: null,
    lastSeen: Date.now(),
    history: {},  // varKey → [{t, v}]
  };
}

// ═══════════════════════════════════════════════════════════
// LOGIN
// ═══════════════════════════════════════════════════════════
function toggleLoginMode() {
  loginMode = loginMode === 'client' ? 'tech' : 'client';
  const isTech = loginMode === 'tech';
  document.getElementById('clientLoginFields').style.display = isTech ? 'none' : 'block';
  document.getElementById('techFields').style.display = isTech ? 'block' : 'none';
  document.getElementById('modeHint').textContent = isTech ? '¿Sos cliente? ' : '¿Sos técnico? ';
  document.getElementById('modeLinkText').textContent = isTech ? 'Acceso con código' : 'Acceso técnico';
}

async function doLogin() {
  const errEl = document.getElementById('loginErr');
  errEl.style.display = 'none';
  // Ensure codes are loaded (fetch is fast if cached)
  if (Object.keys(CLIENT_CODES).length === 0) await loadClientCodes();

  let cfg;
  if (loginMode === 'client') {
    const code = document.getElementById('accessCode').value.trim().toUpperCase();
    if (!code) { showLoginErr('Ingresá tu código de acceso'); return; }
    cfg = CLIENT_CODES[code];
    if (!cfg) { showLoginErr('Código inválido — verificá el código con tu proveedor'); return; }
  } else {
    const rawPath = document.getElementById('tTopic').value.trim().replace(/\/+$/, '');
    const pathParts = rawPath.split('/').filter(Boolean);
    if (pathParts.length < 3) {
      showLoginErr('Ingresá el path completo: namespace/client/device  (ej: agua/vacoto/rom_base_01)');
      return;
    }
    const [pNs, pClient, pDevice] = pathParts;
    cfg = {
      host: document.getElementById('tHost').value.trim(),
      port: parseInt(document.getElementById('tPort').value) || 8884,
      user: document.getElementById('tUser').value.trim(),
      pass: document.getElementById('tPass').value,
      topic: pNs + '/' + pClient + '/' + pDevice + '/#',
      clientFilter: pClient,
      deviceFilter: pDevice,
      techMode: true,
      label: pClient + ' / ' + pDevice,
    };
    if (!cfg.host) { showLoginErr('Ingresá el host del broker'); return; }
  }

  loginCfg = cfg;
  setConn('ing', 'conectando…');

  const clientId = 'hydra_' + Math.random().toString(36).substr(2,8);
  // Build WebSocket URL explicitly to avoid Paho path issues
  // Always use 8884 for WebSocket (8883 = raw MQTT only, doesn't work in browser)
  const wsPort = 8884;
  const wsUrl = 'wss://' + cfg.host + ':' + wsPort + '/mqtt';
  console.log('[Hydra] Connecting to:', wsUrl, 'user:', cfg.user);
  mqtt = new Paho.Client(cfg.host, wsPort, '/mqtt', clientId);
  mqtt.onConnectionLost = onLost;
  mqtt.onMessageArrived = onMsg;

  // Test raw WebSocket first to diagnose
  try {
    const testWs = new WebSocket(wsUrl);
    testWs.onopen  = () => { console.log('[Hydra] Raw WebSocket OK'); testWs.close(); };
    testWs.onerror = (e) => { console.error('[Hydra] Raw WebSocket FAILED:', e); };
  } catch(e) { console.error('[Hydra] WebSocket constructor error:', e); }

  mqtt.connect({
    useSSL: true,
    userName: cfg.user,
    password: cfg.pass,
    keepAliveInterval: 30,
    cleanSession: true,
    onSuccess: onConnected,
    onFailure: (e) => {
      setConn('off', 'desconectado');
      console.error('[Hydra] MQTT connect failed:', e);
      showLoginErr('Error: ' + (e.errorMessage || 'Sin respuesta') + ' | URL: ' + wsUrl);
    }
  });
}

function showLoginErr(msg) {
  const el = document.getElementById('loginErr');
  el.textContent = msg; el.style.display = 'block';
}

function onConnected() {
  setConn('on', 'conectado');
  console.log('[onConnected] clientFilter:', loginCfg.clientFilter, '| deviceFilter:', loginCfg.deviceFilter, '| topic:', loginCfg.topic);

  // ── Ocultar login completamente y resetear scroll ──────────
  const loginScreen = document.getElementById('screenLogin');
  const loginTopbar = document.getElementById('loginTopbar');
  const appTopbar   = document.getElementById('appTopbar');
  if (loginScreen) { loginScreen.classList.remove('active'); loginScreen.style.display = 'none'; }
  if (loginTopbar) loginTopbar.style.display = 'none';
  if (appTopbar)   appTopbar.style.display   = 'flex';
  window.scrollTo(0, 0);

  // Subscribe to data topics
  console.log('[Hydra] Subscribing to:', loginCfg.topic);
  mqtt.subscribe(loginCfg.topic, { qos: 1 });
  const baseTopic = loginCfg.topic.replace('/#','');
  const aiTopic = baseTopic + '/+/+/ai/#';
  console.log('[Hydra] Subscribing to AI:', aiTopic);
  mqtt.subscribe(aiTopic, { qos: 0 });
  console.log('[Hydra] clientFilter:', loginCfg.clientFilter || 'none (tech mode)');

  if (loginCfg.clientFilter) {
    // CLIENT or TECH with specific device: spinner → dashboard
    document.getElementById('waitLabel').textContent = 'Conectado — aguardando datos…';
    document.getElementById('waitSub').textContent = loginCfg.label || loginCfg.clientFilter;
    document.getElementById('waitTopic').textContent = loginCfg.topic;
    showScreen('waiting');
    waitForDeviceData();
  } else {
    // Fallback: no filter set (shouldn't happen with new tech mode)
    document.getElementById('bottomNav').classList.add('vis');
    showScreen('clients');
    refreshClientsList();
  }
}

function waitForDeviceData() {
  let attempts = 0;
  const interval = setInterval(() => {
    attempts++;
    const myDevs = Object.values(devices).filter(d => {
      const cf = loginCfg.clientFilter;
      const df = loginCfg.deviceFilter;
      const clientOk = !cf || d.client.toLowerCase() === cf.toLowerCase();
      const deviceOk = !df || d.device.toLowerCase() === df.toLowerCase();
      if (!clientOk || !deviceOk) console.log('[waitFor] skip:', d.client, d.device, '| filter:', cf, df);
      return clientOk && deviceOk;
    });
    if (attempts === 1) console.log('[waitFor] devices so far:', Object.keys(devices));
    if (myDevs.length > 0) {
      clearInterval(interval);
      document.getElementById('bottomNav').classList.add('vis');
      if (myDevs.length === 1) {
        const dev = myDevs[0];
        openDevice(dev.ns + '/' + dev.client + '/' + dev.device);
      } else {
        openClient(loginCfg.clientFilter || myDevs[0].client);
      }
    } else if (attempts >= 30) {
      clearInterval(interval);
      document.getElementById('waitLabel').textContent = 'Sin respuesta del equipo';
      document.getElementById('waitSub').textContent = 'Verificá que el equipo esté encendido';
      document.getElementById('waitTopic').textContent = loginCfg.topic;
      document.getElementById('bottomNav').classList.add('vis');
    } else {
      const d = '.'.repeat((attempts % 3) + 1);
      document.getElementById('waitLabel').textContent = 'Aguardando datos' + d;
    }
  }, 500);
}

function onLost(resp) {
  if (resp.errorCode !== 0) setConn('off', 'desconectado');
}

// ═══════════════════════════════════════════════════════════
// MESSAGE HANDLER
// ═══════════════════════════════════════════════════════════
function onMsg(msg) {
  const topic = msg.destinationName;
  const payload = msg.payloadString;
  console.log('[MQTT]', topic, '=', payload.slice(0,60));
  // Log parsed parts for first few messages
  if (Object.keys(devices).length < 3) {
    const _p = topic.split('/');
    console.log('[MQTT parsed] ns:', _p[0], '| client:', _p[1], '| device:', _p[2], '| group:', _p[3]);
  }

  const parts = topic.split('/');
  if (parts.length < 4) return;

  const ns = parts[0], client = parts[1], device = parts[2];
  const group = parts[3], key = parts.slice(4).join('/');

  // Skip engine HB
  if (client === 'ai' && device === 'engine') return;

  // Client filter (client mode) — case-insensitive match
  if (loginCfg && loginCfg.clientFilter) {
    const filter = loginCfg.clientFilter.toLowerCase().trim();
    const incoming = client.toLowerCase().trim();
    if (incoming !== filter) {
      console.log('[MQTT] filtered:', incoming, '!== filter:', filter);
      return;
    }
  }

  const devKey = `${ns}/${client}/${device}`;
  if (!devices[devKey]) {
    devices[devKey] = makeDevice(ns, client, device);
    console.log('[onMsg] new device:', devKey, '| clientFilter:', loginCfg && loginCfg.clientFilter);
  }
  const dev = devices[devKey];
  dev.lastSeen = Date.now();

  const fullKey = group + (key ? '/' + key : '');

  if (group === 'alarm') {
    const v = parseInt(payload);
    if (v === 1) dev.alarms[key] = { ts: Date.now() };
    else delete dev.alarms[key];
    if (activeNav === 'clients') refreshClientCard(client);
    // Alarm changed — update alarm section only, not full dashboard
    if (currentDevKey === devKey) updateAlarmSection(devKey);

  } else if (group === 'ai' && key === 'state') {
    try { dev.aiState = JSON.parse(payload); } catch(e){}
    // Only update the state badge, not full re-render
    if (currentDevKey === devKey) updateStateBadge(devKey);

  } else if (group === 'ai' && key === 'report') {
    // Only store if valid JSON object with analysis data (ignore plain text payloads)
    try {
      const parsed = JSON.parse(payload);
      if (parsed && typeof parsed === 'object' && (parsed.analysis || parsed.primary_diagnosis || parsed.diagnostics)) {
        dev.aiReport = parsed;
        console.log('[AI] report received, plugin:', (parsed.analysis||parsed).plugin_id,
          'primary:', ((parsed.analysis||parsed).primary_diagnosis||{}).title || 'none');
        if (currentDevKey === devKey) renderDashboard(devKey);
      }
    } catch(e) {
      console.log('[AI] report parse failed (probably text payload), ignoring');
    }

  } else if (group !== 'event') {
    let val = payload;
    try {
      const p = JSON.parse(payload);
      if (typeof p === 'number' || typeof p === 'boolean') val = p;
      else if (typeof p !== 'object') val = p;
      else val = p;
    } catch(e) {}
    dev.last[fullKey] = val;

    // History for analog/chartable vars
    const lcfg = LABELS[fullKey];
    if (lcfg && lcfg.chart) {
      const num = parseFloat(val);
      if (!isNaN(num)) {
        if (!dev.history[fullKey]) dev.history[fullKey] = [];
        dev.history[fullKey].push({ t: Date.now(), v: num });
        if (dev.history[fullKey].length > HISTORY_MAX)
          dev.history[fullKey].shift();
        updateChart(devKey, fullKey);
      }
    }

    // Update tile in open dashboard (fast, no re-render)
    if (currentDevKey === devKey) partialUpdateTile(fullKey, val);

    // Update client card only if in clients view (throttled)
    if (activeNav === 'clients') {
      const now = Date.now();
      if (!dev._lastCardUpdate || now - dev._lastCardUpdate > 2000) {
        dev._lastCardUpdate = now;
        refreshClientCard(client);
      }
    }
  }
}

// ═══════════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════════
function showScreen(name, goBack) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('screen' + name.charAt(0).toUpperCase() + name.slice(1));
  if (el) {
    el.style.animation = goBack ? 'screenBack .22s ease both' : 'screenIn .22s ease both';
    el.classList.add('active');
    setTimeout(() => { if (el) el.style.animation = ''; }, 300);
  }
  // Toggle login vs app chrome
  const isLogin = (name === 'login');
  const lt = document.getElementById('loginTopbar');
  const at = document.getElementById('appTopbar');
  const ls = document.getElementById('screenLogin');
  if (lt) lt.style.display = isLogin ? 'flex' : 'none';
  if (at) at.style.display = isLogin ? 'none'  : 'flex';
  if (ls && !isLogin) ls.classList.remove('active');
  // Back button visibility
  document.getElementById('btnBack').classList.toggle('vis', !['clients','waiting'].includes(name));
  // Bottom nav visibility
  document.getElementById('bottomNav').classList.toggle('vis', !['login','waiting'].includes(name));
}

function navTo(tab) {
  activeNav = tab;
  ['navClients','navAlarms','navConfig'].forEach(id =>
    document.getElementById(id).classList.toggle('active', id === 'nav' + tab.charAt(0).toUpperCase() + tab.slice(1)));
  currentDevKey = null;
  charts = {};

  if (tab === 'clients') {
    refreshClientsList();
    showScreen('clients');
  } else if (tab === 'alarms') {
    renderAlarmsScreen();
  } else if (tab === 'config') {
    renderConfigScreen();
  }
}

function goBack() {
  const active = document.querySelector('.screen.active');
  if (!active) return;
  const id = active.id;
  if (id === 'screenDashboard') {
    // Client mode with single device: no back, stay on dashboard
    if (loginCfg && loginCfg.clientFilter) {
      const myDevs = Object.values(devices).filter(d => d.client === loginCfg.clientFilter);
      if (myDevs.length <= 1) return;
      currentDevKey = null; charts = {};
      renderDevicesScreen(loginCfg.clientFilter, true);
    } else {
      currentDevKey = null; charts = {};
      renderDevicesScreen(currentClientFilter, true);
    }
  } else if (id === 'screenDevices') {
    currentClientFilter = null;
    navTo('clients');
  }
}

function openClient(clientId) {
  currentClientFilter = clientId;
  renderDevicesScreen(clientId);
}

function openDevice(devKey) {
  currentDevKey = devKey;
  charts = {};
  showScreen('dashboard');
  document.getElementById('btnBack').classList.add('vis');
  renderDashboard(devKey);
}

// ═══════════════════════════════════════════════════════════
// CLIENTS LIST
// ═══════════════════════════════════════════════════════════
function getClients() {
  const map = {};
  Object.values(devices).forEach(dev => {
    if (!map[dev.client]) map[dev.client] = [];
    map[dev.client].push(dev);
  });
  return map;
}

function refreshClientsList() {
  const clients = getClients();
  const list = document.getElementById('clientsList');
  const empty = document.getElementById('clientsEmpty');

  if (Object.keys(clients).length === 0) {
    list.innerHTML = '';
    empty.style.display = 'flex';
    return;
  }
  empty.style.display = 'none';

  // Build or update each client card
  Object.entries(clients).forEach(([clientId, devList], idx) => {
    const cardId = 'cc_' + clientId;
    let card = document.getElementById(cardId);
    if (!card) {
      card = document.createElement('div');
      card.id = cardId;
      card.className = 'client-card';
      card.style.animationDelay = (idx * 60) + 'ms';
      card.onclick = () => openClient(clientId);
      list.appendChild(card);
    }
    card.innerHTML = buildClientCardHTML(clientId, devList);
  });
}

function buildClientCardHTML(clientId, devList) {
  const totalAlarms = devList.reduce((n, d) =>
    n + Object.keys(d.alarms).filter(k => k !== 'offline').length, 0);
  const onlineCount = devList.filter(d => {
    const age = (Date.now() - d.lastSeen) / 1000;
    return age < 200 && !d.alarms['offline'];
  }).length;

  const icons = ['💧','🏭','⚙','🔬','🌊'];
  const icon = icons[clientId.charCodeAt(0) % icons.length];

  let chips = `<span class="client-stat-chip online">● ${onlineCount}/${devList.length} online</span>`;
  if (totalAlarms > 0) chips += `<span class="client-stat-chip alarm">⚠ ${totalAlarms} alarmas</span>`;
  devList.forEach(d => chips += `<span class="client-stat-chip">${d.device}</span>`);

  return `
    <div class="client-header">
      <div class="client-icon">${icon}</div>
      <div class="client-info">
        <div class="client-name">${clientId}</div>
        <div class="client-meta">agua/${clientId} · ${devList.length} equipo(s)</div>
      </div>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text3)">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
    <div class="client-stats">${chips}</div>`;
}

function refreshClientCard(clientId) {
  const card = document.getElementById('cc_' + clientId);
  if (!card) return;
  const devList = Object.values(devices).filter(d => d.client === clientId);
  card.innerHTML = buildClientCardHTML(clientId, devList);
}

// ═══════════════════════════════════════════════════════════
// DEVICES SCREEN
// ═══════════════════════════════════════════════════════════
function renderDevicesScreen(clientId, isBack) {
  const devList = Object.values(devices).filter(d => d.client === clientId);
  document.getElementById('devicesTitle').textContent = clientId.toUpperCase();
  const list = document.getElementById('devicesList');
  list.innerHTML = '';

  devList.forEach((dev, idx) => {
    const devKey = `${dev.ns}/${dev.client}/${dev.device}`;
    const state = dev.aiState ? dev.aiState.state : (dev.last['stat/status'] || 'INIT');
    const stateClass = getStateClass(state);
    const alarmCount = Object.keys(dev.alarms).filter(k => k !== 'offline').length;

    const card = document.createElement('div');
    card.className = 'device-card';
    card.style.animationDelay = (idx * 50) + 'ms';
    card.onclick = () => openDevice(devKey);
    card.innerHTML = `
      <div class="device-header">
        <span class="state-badge ${stateClass}">${state}</span>
        <div class="device-name">
          <div class="device-id">${dev.device}</div>
          <div class="device-path">${dev.ns}/${dev.client}</div>
        </div>
        ${alarmCount > 0 ? `<span class="alarm-pill">⚠ ${alarmCount}</span>` : ''}
        <span style="color:var(--text3);font-size:12px">›</span>
      </div>`;
    list.appendChild(card);
  });

  showScreen('devices', isBack);
}

// ═══════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════
function renderDashboard(devKey) {
  const dev = devices[devKey];
  if (!dev) return;
  document.getElementById('dashContent').innerHTML = buildDashHTML(dev, devKey);
  // Initialize charts after DOM is ready
  setTimeout(() => initCharts(devKey), 50);
}

function buildDashHTML(dev, devKey) {
  const state = dev.aiState ? dev.aiState.state : (dev.last['stat/status'] || '—');
  const stateClass = getStateClass(state);

  // Stats bar
  const uptime = dev.last['stat/uptime_s'];
  const rssi   = dev.last['stat/rssi_dbm'];
  const fw     = dev.last['stat/fw_version'];
  const hb     = dev.last['stat/hb'];
  let statsBar = '';
  if (uptime !== undefined || rssi !== undefined) {
    statsBar = `<div class="stats-bar" style="margin-bottom:10px">`;
    if (uptime !== undefined) statsBar += `<span class="stat-chip">⏱ <b>${fmtUptime(uptime)}</b></span>`;
    if (rssi   !== undefined) statsBar += `<span class="stat-chip">📶 <b>${rssi} dBm</b></span>`;
    if (fw) statsBar += `<span class="stat-chip">fw <b>${fw}</b></span>`;
    if (hb !== undefined) statsBar += `<span class="stat-chip">hb <b>${hb}</b></span>`;
    statsBar += `</div>`;
  }

  // Header
  let html = `
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
      <span class="state-badge ${stateClass}" style="font-size:11px;padding:5px 12px">${state}</span>
      <div style="flex:1;min-width:0">
        <div style="font-size:16px;font-weight:700">${dev.device}</div>
        <div style="font-size:10px;color:var(--text3);font-family:var(--mono)">${dev.ns}/${dev.client}</div>
      </div>
      <button onclick="requestDiagnosis('${devKey}')"
        style="background:rgba(0,136,204,.15);border:1px solid rgba(0,136,204,.3);
               border-radius:8px;color:var(--accent);font-size:11px;font-weight:600;
               padding:7px 12px;cursor:pointer;flex-shrink:0;white-space:nowrap"
        id="diagBtn_${devKey.replace(/\//g,'_')}">
        🔍 Diagnosticar
      </button>
    </div>
    ${statsBar}`;

  // Alarms
  const activeAlarms = Object.entries(dev.alarms).filter(([k]) => k !== 'offline');
  html += `<div class="sec-hdr">Alarmas</div>`;
  html += `<div id="alarmSection_${devKey.replace(/\//g,'_')}">`;
  if (activeAlarms.length === 0) {
    html += `<div class="no-alarm">✓ Sin alarmas activas</div>`;
  } else {
    activeAlarms.forEach(([key, data]) => {
      const dur = Math.round((Date.now() - data.ts) / 60000);
      html += `<div class="alarm-row">
        <span>⚠</span>
        <span class="alarm-key">${ALARM_LABELS[key] || key}</span>
        <span class="alarm-dur">${dur} min</span>
      </div>`;
    });
  }
  html += `</div>`;

  // Digital I/O tiles
  // ── Render each section from the guide ──────────────────────────
  SECTIONS.forEach(sec => {
    // Get all vars for this section, with value (or undefined if not yet received)
    const items = sec.vars.map(v => ({
      key: v.k, val: dev.last[v.k], cfg: v
    }));

    // Only show section if at least one var has been received
    const hasAny = items.some(item => item.val !== undefined);
    if (!hasAny) return;

    html += `<div class="sec-hdr">${sec.label}</div><div class="tiles" id="sec_${sec.key}">`;
    items.forEach(item => {
      html += renderTile(item);
    });
    html += `</div>`;
  });

  // ── Unknown vars received from device not in guide ──────────────
  const knownKeys = new Set(Object.keys(LABELS));
  const unknownAnalog = Object.keys(dev.last).filter(k =>
    !knownKeys.has(k) &&
    (k.startsWith('tele/') || k.startsWith('stat/')) &&
    !k.includes('hb') && !k.includes('state_code') && !k.includes('params')
  );
  if (unknownAnalog.length > 0) {
    html += `<div class="sec-hdr">Otros (no catalogados)</div><div class="tiles">`;
    unknownAnalog.forEach(k => {
      const val = dev.last[k];
      const num = parseFloat(val);
      html += renderTile({
        key: k,
        val: val,
        cfg: {
          label: k.split('/').pop().replace(/_/g,' '),
          type: (!isNaN(num) && val !== '' && val !== null) ? 'analog' : 'text',
          unit: ''
        }
      });
    });
    html += `</div>`;
  }

    // Charts for analog vars that have history
  const chartVars = Object.keys(dev.history).filter(k => dev.history[k].length > 1);
  if (chartVars.length > 0) {
    html += `<div class="sec-hdr" data-sec="charts">Gráficos (última hora)</div>`;
    chartVars.forEach(varKey => {
      const lcfg = LABELS[varKey] || {};
      const latest = dev.history[varKey].slice(-1)[0];
      const latestVal = latest ? latest.v.toFixed(2) : '—';
      html += `<div class="chart-wrap" id="cw_${devKey}_${varKey.replace(/\//g,'_')}">
        <div class="chart-title">
          ${lcfg.label || varKey}
          <span>${latestVal} ${lcfg.unit || ''}</span>
        </div>
        <div class="chart-canvas-wrap">
          <canvas id="ch_${devKey}_${varKey.replace(/\//g,'_')}"></canvas>
        </div>
      </div>`;
    });
  }

  // AI Diagnosis — uses ai/report if available, else ai/state signals
  const rawReport = dev.aiReport || null;
  const analysis  = rawReport ? (rawReport.analysis || rawReport) : null;
  const primary   = analysis ? (analysis.primary_diagnosis || null) : null;
  const diags     = analysis ? (analysis.diagnostics || []) : [];
  const kpis      = analysis ? (analysis.kpis || {}) : {};
  const aiSt      = dev.aiState || null;

  // Determine overall health
  const hasAlarms  = Object.keys(dev.alarms).filter(k => k !== 'offline').length > 0;
  const devState   = dev.aiState ? dev.aiState.state : (dev.last['stat/status'] || '');
  const isRunning  = devState === 'RUNNING';
  const isIdle     = devState === 'IDLE';
  const allOk      = !hasAlarms && (isRunning || isIdle) && !primary;

  html += `<div class="sec-hdr">Diagnóstico IA</div>`;

  if (primary) {
    // Full diagnosis from ai/report
    const score = primary.score || 0;
    const sev   = (primary.severity || 'INFO').toLowerCase();
    const sevCls = sev === 'alarm' ? 'alarm' : sev === 'warn' ? 'warn' : 'info';
    const bc = primary.because || [];
    const ac = primary.actions || [];
    const rw = primary.resolve_when || [];
    html += `<div class="diag-box">
      <div class="diag-header">
        <div class="diag-title">${primary.title || '—'}</div>
        <span class="diag-badge db-${sevCls}">~${score}%</span>
      </div>
      ${bc.length > 0 ? '<div style="margin-bottom:5px">' + bc.slice(0,5).map(b=>`<div class="diag-ev">${b}</div>`).join('') + '</div>' : ''}
      ${ac.length > 0 ? '<hr class="diag-sep"><div>' + ac.slice(0,4).map(a=>`<div class="diag-act">${a}</div>`).join('') + '</div>' : ''}
      ${rw.length > 0 ? '<hr class="diag-sep"><div style="font-size:10px;color:var(--text3);margin-top:4px">' + rw.slice(0,2).map(r=>`<div style="padding:1px 0 1px 12px;position:relative"><span style="position:absolute;left:0;color:var(--green)">✓</span>${r}</div>`).join('') + '</div>' : ''}
    </div>`;

    // Show secondary diagnoses if available
    if (diags.length > 1) {
      html += '<div style="margin-top:6px">';
      diags.slice(1,3).filter(d => d.score >= 50).forEach(d => {
        const sc = d.score || 0;
        const sv = (d.severity||'INFO').toLowerCase();
        html += `<div class="diag-box" style="margin-top:6px;opacity:.8">
          <div class="diag-header">
            <div class="diag-title" style="font-size:12px">${d.title||'—'}</div>
            <span class="diag-badge db-${sv==='alarm'?'alarm':sv==='warn'?'warn':'info'}" style="font-size:8px">~${sc}%</span>
          </div>
        </div>`;
      });
      html += '</div>';
    }

  } else if (aiSt) {
    // No full report yet — show state summary from ai/state
    const st      = aiSt.state || '—';
    const sigs    = aiSt.signals || {};
    const openAlm = aiSt.open_alarms || [];
    const dedic   = aiSt.dedicated || {};
    const learn   = aiSt.learn || {};

    html += `<div class="diag-box">
      <div class="diag-header">
        <div class="diag-title">Motor activo — estado en tiempo real</div>
        <span class="diag-badge db-info">${st}</span>
      </div>`;

    // Show open alarms from ai/state
    if (openAlm.length > 0) {
      html += '<hr class="diag-sep">';
      openAlm.slice(0,4).forEach(a => {
        const dur = a.set_ts ? Math.round((Date.now()/1000 - a.set_ts)/60) : '?';
        html += `<div class="diag-ev" style="color:var(--red)">⚠ ${ALARM_LABELS[a.alarm_key] || a.alarm_key} (${dur} min)</div>`;
      });
    }

    // Key signals
    const sigItems = [];
    if (sigs.run !== null && sigs.run !== undefined)          sigItems.push('run=' + sigs.run);
    if (sigs.tank_demand !== null && sigs.tank_demand !== undefined) sigItems.push('demanda=' + sigs.tank_demand);
    if (sigs.cistern_ok !== null && sigs.cistern_ok !== undefined)   sigItems.push('cisterna=' + sigs.cistern_ok);
    if (sigs.pressure_ok !== null && sigs.pressure_ok !== undefined) sigItems.push('presión=' + sigs.pressure_ok);
    if (sigs.flow_lpm !== null && sigs.flow_lpm !== undefined)       sigItems.push('caudal=' + parseFloat(sigs.flow_lpm).toFixed(2) + ' L/min');

    if (sigItems.length > 0) {
      html += '<hr class="diag-sep">';
      sigItems.forEach(s => { html += `<div class="diag-ev">${s}</div>`; });
    }

    // Dedicated mode info
    if (dedic.enabled) {
      html += `<hr class="diag-sep"><div class="diag-ev" style="color:var(--accent)">🔴 IA dedicada activa${dedic.auto_control ? ' · auto-control ON' : ''}</div>`;
    }

    // Learn progress
    if (learn.running) {
      const pct = learn.target_prod_s > 0 ? Math.round(learn.prod_accum_s / learn.target_prod_s * 100) : 0;
      html += `<hr class="diag-sep"><div class="diag-ev" style="color:var(--yellow)">📊 Aprendiendo baseline: ${pct}%</div>`;
    }

    html += `<hr class="diag-sep"><div style="font-size:10px;color:var(--text3);margin-top:4px">
      Para diagnóstico completo, generá un informe desde la app IA en la PC.
    </div></div>`;

  } else if (allOk) {
    // Everything is fine — show positive summary
    const run_s  = dev.last['stat/uptime_s'];
    const flow   = dev.last['tele/flow_perm_lpm'] || dev.last['tele/flow_lpm'];
    const cond   = dev.last['tele/cond_perm_us'];
    const reject = kpis.ro_rejection_ratio;
    html += `<div class="diag-box" style="background:rgba(0,230,118,.05);border-color:rgba(0,230,118,.2)">
      <div class="diag-header">
        <div class="diag-title" style="color:var(--green)">✓ Operación normal</div>
        <span class="diag-badge" style="background:rgba(0,230,118,.15);color:var(--green)">${devState}</span>
      </div>
      <div style="margin-top:6px">
        ${flow !== undefined ? `<div class="diag-ev">Caudal: ${parseFloat(flow).toFixed(2)} L/min</div>` : ''}
        ${cond !== undefined ? `<div class="diag-ev">Conductividad permeado: ${parseFloat(cond).toFixed(1)} µS/cm</div>` : ''}
        ${reject !== undefined ? `<div class="diag-ev">Rechazo de sales: ${(reject*100).toFixed(1)}%</div>` : ''}
        ${run_s !== undefined ? `<div class="diag-ev">Uptime: ${fmtUptime(run_s)}</div>` : ''}
      </div>
      ${rawReport ? '' : '<hr class="diag-sep"><div style="font-size:10px;color:var(--text3)">Generá un informe desde la PC para diagnóstico detallado.</div>'}
    </div>`;

  } else if (aiSt) {
    // No full report yet — show state summary from ai/state
    const st      = aiSt.state || '—';
    const sigs    = aiSt.signals || {};
    const openAlm = aiSt.open_alarms || [];
    const dedic   = aiSt.dedicated || {};
    const learn   = aiSt.learn || {};
    html += `<div class="diag-box">
      <div class="diag-header">
        <div class="diag-title">Motor activo — estado en tiempo real</div>
        <span class="diag-badge db-info">${st}</span>
      </div>`;
    if (openAlm.length > 0) {
      html += '<hr class="diag-sep">';
      openAlm.slice(0,4).forEach(a => {
        const dur = a.set_ts ? Math.round((Date.now()/1000 - a.set_ts)/60) : '?';
        html += `<div class="diag-ev" style="color:var(--red)">⚠ ${ALARM_LABELS[a.alarm_key] || a.alarm_key} (${dur} min)</div>`;
      });
    }
    const sigItems = [];
    if (sigs.run !== null && sigs.run !== undefined)           sigItems.push('run=' + sigs.run);
    if (sigs.tank_demand !== undefined)  sigItems.push('demanda=' + sigs.tank_demand);
    if (sigs.cistern_ok  !== undefined)  sigItems.push('cisterna=' + sigs.cistern_ok);
    if (sigs.pressure_ok !== undefined)  sigItems.push('presión=' + sigs.pressure_ok);
    if (sigs.flow_lpm    !== undefined)  sigItems.push('caudal=' + parseFloat(sigs.flow_lpm).toFixed(2) + ' L/min');
    if (sigItems.length > 0) {
      html += '<hr class="diag-sep">';
      sigItems.forEach(s => { html += `<div class="diag-ev">${s}</div>`; });
    }
    if (dedic.enabled) {
      html += `<hr class="diag-sep"><div class="diag-ev" style="color:var(--accent)">🔴 IA dedicada activa</div>`;
    }
    if (learn.running) {
      const pct = learn.target_prod_s > 0 ? Math.round(learn.prod_accum_s / learn.target_prod_s * 100) : 0;
      html += `<hr class="diag-sep"><div class="diag-ev" style="color:var(--yellow)">📊 Aprendiendo baseline: ${pct}%</div>`;
    }
    html += `<hr class="diag-sep"><div style="font-size:10px;color:var(--text3);margin-top:4px">
      Presioná 🔍 Diagnosticar para diagnóstico completo.
    </div></div>`;

  } else {
    html += `<div class="diag-box" style="opacity:.5">
      <div class="diag-title">Motor IA no conectado</div>
    </div>`;
  }

  // Raw topics (tech mode)
  if (loginCfg && loginCfg.techMode) {
    const entries = Object.entries(dev.last).sort();
    html += `<div class="sec-hdr" style="margin-top:14px">Topics crudos</div>
    <div class="raw-toggle" onclick="this.nextSibling.classList.toggle('vis');this.textContent=this.nextSibling.classList.contains('vis')?'▼ ocultar topics crudos':'▶ ver topics crudos (${entries.length})'">▶ ver topics crudos (${entries.length})</div>
    <div class="raw-table">
    ${entries.map(([k,v])=>`<div class="raw-row"><span class="raw-k">${k}</span><span class="raw-v">${typeof v==='object'?JSON.stringify(v).slice(0,50):String(v)}</span></div>`).join('')}
    </div>`;
  }

  return html;
}

function buildTiles(dev, filterFn) {
  // Legacy helper — still used by partialUpdateTile
  return Object.entries(LABELS)
    .filter(([k, cfg]) => !cfg.hide && filterFn(cfg))
    .map(([k, cfg]) => ({ key: k, val: dev.last[k], cfg }));
}

function renderTile(t) {
  const { key, val, cfg } = t;
  const safeKey = key.replace(/\//g,'_');
  const hasVal  = val !== undefined && val !== null && val !== '';

  // ── DIMMED tile: variable known but no data yet ──
  if (!hasVal) {
    const isDig = cfg.type === 'digital';
    return `<div class="tile t-off" id="tile_${safeKey}" style="opacity:.35">
      <div class="tile-label">${cfg.label}</div>
      ${isDig
        ? `<div class="dig-row"><div class="dig-led" style="background:var(--border2)"></div><div class="dig-label off">—</div></div>`
        : `<div class="tile-val" style="font-size:15px;color:var(--text3)">—<span class="tile-unit">${cfg.unit||''}</span></div>`
      }
    </div>`;
  }

  let cls = 'tile';
  let inner = '';

  if (cfg.type === 'digital') {
    const isOn    = (val == 1 || val === true || val === 'true');
    const isAlarm = cfg.invert ? isOn : false;
    cls += isAlarm ? ' t-alarm' : (isOn ? ' t-on' : ' t-off');
    const ledCls = isAlarm ? 'led-alarm' : (isOn ? 'led-on' : 'led-off');
    const lblCls = isAlarm ? 'alarm' : (isOn ? 'on' : 'off');
    inner = `<div class="tile-label">${cfg.label}</div>
      <div class="dig-row">
        <div class="dig-led ${ledCls}" id="led_${safeKey}"></div>
        <div class="dig-label ${lblCls}" id="dv_${safeKey}">${isOn ? 'ON' : 'OFF'}</div>
      </div>`;

  } else if (cfg.type === 'analog') {
    const num = parseFloat(val);
    const fmt = isNaN(num) ? String(val) : (num < 10 ? num.toFixed(2) : num.toFixed(1));
    cls += ' t-analog';
    inner = `<div class="tile-label">${cfg.label}</div>
      <div class="tile-val big" id="av_${safeKey}">${fmt}<span class="tile-unit">${cfg.unit||''}</span></div>`;

  } else if (cfg.type === 'number') {
    cls += ' t-text';
    inner = `<div class="tile-label">${cfg.label}</div>
      <div class="tile-val" id="av_${safeKey}">${val}</div>`;

  } else {
    cls += ' t-text';
    inner = `<div class="tile-label">${cfg.label}</div>
      <div class="tile-val" style="font-size:13px" id="av_${safeKey}">${val}</div>`;
  }

  return `<div class="${cls}" id="tile_${safeKey}">${inner}</div>`;
}

function partialUpdateTile(fullKey, val) {
  const safeKey = fullKey.replace(/\//g,'_');
  const cfg = LABELS[fullKey];
  if (!cfg) return;

  const tile = document.getElementById('tile_' + safeKey);

  if (!tile) {
    // Tile doesn't exist yet — this var just arrived for the first time
    // Find the section container and add it, or do a targeted section update
    addTileToSection(fullKey, val, cfg);
    return;
  }

  // Tile exists — update in-place (fast, no re-render)
  if (cfg.type === 'digital') {
    const isOn    = (val == 1 || val === true || val === 'true');
    const isAlarm = cfg.invert ? isOn : false;
    tile.className = 'tile ' + (isAlarm ? 't-alarm' : isOn ? 't-on' : 't-off');
    tile.style.opacity = '';
    const led = document.getElementById('led_' + safeKey);
    const dv  = document.getElementById('dv_'  + safeKey);
    if (led) led.className = 'dig-led ' + (isAlarm ? 'led-alarm' : isOn ? 'led-on' : 'led-off');
    if (dv)  { dv.className = 'dig-label ' + (isAlarm ? 'alarm' : isOn ? 'on' : 'off'); dv.textContent = isOn ? 'ON' : 'OFF'; }
  } else {
    tile.style.opacity = '';
    const av = document.getElementById('av_' + safeKey);
    if (av) {
      if (cfg.type === 'analog') {
        const num = parseFloat(val);
        const fmt = isNaN(num) ? String(val) : (num < 10 ? num.toFixed(2) : num.toFixed(1));
        av.innerHTML = fmt + `<span class="tile-unit">${cfg.unit||''}</span>`;
      } else {
        av.textContent = val;
      }
    }
  }
}

function addTileToSection(fullKey, val, cfg) {
  // Find the section this var belongs to
  const sec = SECTIONS.find(s => s.vars.some(v => v.k === fullKey));
  if (!sec) return;

  const secId = 'sec_' + sec.key;
  let tilesDiv = document.getElementById(secId);

  if (!tilesDiv) {
    // Section doesn't exist yet — create it
    const dashContent = document.getElementById('dashContent');
    if (!dashContent) return;
    // Find the right insertion point (after alarms, before charts)
    const chartsHdr = dashContent.querySelector('[data-sec="charts"]');
    const secHtml = `<div class="sec-hdr">${sec.label}</div><div class="tiles" id="${secId}"></div>`;
    if (chartsHdr) {
      chartsHdr.insertAdjacentHTML('beforebegin', secHtml);
    } else {
      dashContent.insertAdjacentHTML('beforeend', secHtml);
    }
    tilesDiv = document.getElementById(secId);
  }

  if (tilesDiv) {
    tilesDiv.insertAdjacentHTML('beforeend', renderTile({ key: fullKey, val, cfg }));
  }
}

function updateAlarmSection(devKey) {
  // Update just the alarms part of the dashboard without full re-render
  const dev = devices[devKey];
  if (!dev) return;
  const alarmDiv = document.getElementById('alarmSection_' + devKey.replace(/\//g,'_'));
  if (!alarmDiv) { renderDashboard(devKey); return; } // fallback

  const activeAlarms = Object.entries(dev.alarms).filter(([k]) => k !== 'offline');
  if (activeAlarms.length === 0) {
    alarmDiv.innerHTML = `<div class="no-alarm">✓ Sin alarmas activas</div>`;
  } else {
    alarmDiv.innerHTML = activeAlarms.map(([key, data]) => {
      const dur = Math.round((Date.now() - data.ts) / 60000);
      return `<div class="alarm-row"><span>⚠</span>
        <span class="alarm-key">${ALARM_LABELS[key] || key}</span>
        <span class="alarm-dur">${dur} min</span></div>`;
    }).join('');
  }
}

function updateStateBadge(devKey) {
  const dev = devices[devKey];
  if (!dev) return;
  const state = dev.aiState ? dev.aiState.state : (dev.last['stat/status'] || '—');
  const badge = document.querySelector('#dashContent .state-badge');
  if (badge) {
    badge.textContent = state;
    badge.className = 'state-badge ' + getStateClass(state);
  }
}

// ═══════════════════════════════════════════════════════════
// CHARTS
// ═══════════════════════════════════════════════════════════
function initCharts(devKey) {
  const dev = devices[devKey];
  if (!dev) return;

  Object.keys(dev.history).forEach(varKey => {
    const canvasId = 'ch_' + devKey + '_' + varKey.replace(/\//g,'_');
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    if (charts[canvasId]) { charts[canvasId].destroy(); }

    const data = dev.history[varKey];
    const color = CHART_COLORS[varKey] || '#00d4ff';
    const lcfg  = LABELS[varKey] || {};

    charts[canvasId] = new Chart(canvas, {
      type: 'line',
      data: {
        labels: data.map(p => fmtTime(p.t)),
        datasets: [{
          data: data.map(p => p.v),
          borderColor: color,
          backgroundColor: color + '15',
          borderWidth: 1.5,
          pointRadius: 0,
          fill: true,
          tension: 0.3,
        }]
      },
      options: {
        animation: false,
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: {
          mode: 'index', intersect: false,
          backgroundColor: 'rgba(14,21,37,0.95)',
          titleColor: '#7a9cc4', bodyColor: '#e2ecff',
          borderColor: '#1e2d45', borderWidth: 1,
          callbacks: { label: ctx => `${ctx.parsed.y.toFixed(2)} ${lcfg.unit||''}` }
        }},
        scales: {
          x: { display: false },
          y: {
            display: true,
            grid: { color: 'rgba(30,45,69,0.6)', drawBorder: false },
            ticks: { color: '#3d5470', font: { size: 9, family: "'JetBrains Mono'" }, maxTicksLimit: 4 },
            border: { display: false },
          }
        },
        interaction: { mode: 'nearest', axis: 'x', intersect: false },
      }
    });
  });
}

function updateChart(devKey, varKey) {
  if (currentDevKey !== devKey) return;
  const canvasId = 'ch_' + devKey + '_' + varKey.replace(/\//g,'_');
  const chart = charts[canvasId];
  const dev = devices[devKey];
  if (!chart || !dev) {
    // Chart may not exist yet if this is the first data — schedule a re-render
    if (currentDevKey === devKey && !document.getElementById(canvasId)) {
      renderDashboard(devKey);
    }
    return;
  }
  const data = dev.history[varKey];
  chart.data.labels = data.map(p => fmtTime(p.t));
  chart.data.datasets[0].data = data.map(p => p.v);
  chart.update('none');
}

// ═══════════════════════════════════════════════════════════
// ALARMS SCREEN
// ═══════════════════════════════════════════════════════════
function renderAlarmsScreen() {
  const allAlarms = [];
  Object.values(devices).forEach(dev => {
    Object.entries(dev.alarms).forEach(([key, data]) => {
      if (key === 'offline') return;
      allAlarms.push({ dev, key, data });
    });
  });

  let html = '<div class="screen-title">Alarmas activas</div>';
  if (allAlarms.length === 0) {
    html += `<div class="empty"><div class="empty-icon">✅</div><h3>Sin alarmas</h3><p>Todos los equipos operan sin alertas.</p></div>`;
  } else {
    html += '<div class="alarm-list">';
    allAlarms.forEach(({ dev, key, data }) => {
      const dur = Math.round((Date.now() - data.ts) / 60000);
      html += `<div class="alarm-row" onclick="openDevice('${dev.ns}/${dev.client}/${dev.device}')">
        <span>⚠</span>
        <div style="flex:1;min-width:0">
          <div class="alarm-key">${ALARM_LABELS[key] || key}</div>
          <div style="font-size:10px;color:var(--text3);font-family:var(--mono)">${dev.ns}/${dev.client}/${dev.device}</div>
        </div>
        <span class="alarm-dur">${dur} min</span>
      </div>`;
    });
    html += '</div>';
  }

  const screen = document.getElementById('screenClients');
  screen.innerHTML = html;
  showScreen('clients');
}

// ═══════════════════════════════════════════════════════════
// CONFIG SCREEN
// ═══════════════════════════════════════════════════════════
function renderConfigScreen() {
  const devCount = Object.keys(devices).length;
  const connInfo = loginCfg || {};

  let shareLinks = '';
  if (!connInfo.techMode) {
    Object.values(devices).forEach(dev => {
      const code = Object.entries(CLIENT_CODES).find(([c, cfg]) => cfg.clientFilter === dev.client);
      const link = `${location.href.split('?')[0]}?code=${code ? code[0] : ''}`;
      shareLinks += `<div class="client-card" style="cursor:default" onclick="copyText('${link}')">
        <div class="client-header">
          <div class="client-info">
            <div class="client-name">${dev.device}</div>
            <div class="client-meta">${dev.ns}/${dev.client}/${dev.device}</div>
          </div>
          <span style="font-size:11px;color:var(--text3)">📋 copiar link</span>
        </div>
      </div>`;
    });
  }

  const screen = document.getElementById('screenClients');
  screen.innerHTML = `
    <div class="screen-title">Configuración</div>
    <div class="client-card" style="cursor:default;margin-bottom:16px">
      <div class="client-header">
        <div class="client-info">
          <div class="client-name">Conexión activa</div>
          <div class="client-meta">${connInfo.host}:${connInfo.port}</div>
        </div>
        <span class="client-stat-chip online">● conectado</span>
      </div>
      <div class="client-stats">
        <span class="client-stat-chip">user: ${connInfo.user}</span>
        <span class="client-stat-chip">${devCount} equipos detectados</span>
        <span class="client-stat-chip">${connInfo.techMode ? 'modo técnico' : 'modo cliente'}</span>
      </div>
    </div>
    ${shareLinks ? `<div class="screen-title">Links para clientes</div>${shareLinks}` : ''}
    <button class="login-btn" style="max-width:400px;margin-top:16px" onclick="doLogout()">Cerrar sesión</button>`;

  showScreen('clients');
}

function doLogout() {
  if (mqtt && mqtt.isConnected()) mqtt.disconnect();
  mqtt = null; devices = {}; loginCfg = null; charts = {};
  document.getElementById('bottomNav').classList.remove('vis');
  document.getElementById('btnBack').classList.remove('vis');
  setConn('off', 'desconectado');
  devices = {};
  // Restore login screen
  const _ls = document.getElementById('screenLogin');
  const _lt = document.getElementById('loginTopbar');
  const _at = document.getElementById('appTopbar');
  if (_ls) { _ls.style.display = ''; _ls.classList.remove('active'); }
  if (_lt) _lt.style.display = 'flex';
  if (_at) _at.style.display = 'none';
  showScreen('login', true);
  window.scrollTo(0, 0);
}

function copyText(txt) {
  navigator.clipboard.writeText(txt).then(() => alert('Link copiado:\n' + txt));
}

// ═══════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════
function setConn(state, label) {
  const b = document.getElementById('connBadge');
  b.style.display = 'flex';
  b.className = 'conn-badge ' + (state === 'on' ? 'on' : state === 'ing' ? 'ing' : '');
  document.getElementById('connLabel').textContent = label;
}

function getStateClass(state) {
  const s = String(state).toUpperCase();
  const map = { 'RUNNING':'s-RUNNING','IDLE':'s-IDLE','STARTING':'s-STARTING',
    'OFFLINE':'s-OFFLINE','LEARNING':'s-LEARNING','WAIT_CISTERN':'s-WAIT_CISTERN' };
  return map[s] || 's-default';
}

function requestDiagnosis(devKey) {
  if (!mqtt || !mqtt.isConnected()) {
    alert('Sin conexión al broker');
    return;
  }
  const dev = devices[devKey];
  if (!dev) return;

  // Show loading state on button
  const btn = document.getElementById('diagBtn_' + devKey.replace(/\//g,'_'));
  if (btn) {
    btn.textContent = '⏳ Solicitando…';
    btn.disabled = true;
    setTimeout(() => {
      if (btn) { btn.textContent = '🔍 Diagnosticar'; btn.disabled = false; }
    }, 8000);
  }

  // Publish cmd/report to the device topic — IA will respond with ai/report
  const topic = dev.ns + '/' + dev.client + '/' + dev.device + '/cmd/report';
  const payload = JSON.stringify({
    sections: { production: 1, alarms: 1, timeline: 0, diagnosis: 1 }
  });
  mqtt.publish(topic, payload, 1, false);
  console.log('[PWA] Diagnosis requested:', topic);
}

function fmtUptime(s) {
  s = parseInt(s) || 0;
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60);
  if (h > 24) return `${Math.floor(h/24)}d ${h%24}h`;
  if (h > 0) return `${h}h ${m}m`;
  return `${m}m ${s%60}s`;
}

function fmtTime(ts) {
  const d = new Date(ts);
  return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
}

// ═══════════════════════════════════════════════════════════
// URL CODE AUTO-LOGIN
// ═══════════════════════════════════════════════════════════
// Show login screen on load
showScreen('login');

// Auto-login from URL ?code=XXXXX
const urlCode = new URLSearchParams(location.search).get('code');
if (urlCode) {
  document.getElementById('accessCode').value = urlCode.toUpperCase();
  // Wait for clients.json to load, then login
  loadClientCodes().then(() => {
    if (CLIENT_CODES[urlCode.toUpperCase()]) {
      setTimeout(doLogin, 100);
    }
  });
} else {
  // Pre-load codes in background so first login is instant
  loadClientCodes();
}
</script>
