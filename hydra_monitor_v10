      { k:'stat/enabled',    label:'Habilitado',    type:'digital' },
      { k:'stat/locked',     label:'Bloqueado',     type:'digital', invert:true },
      { k:'stat/retries',    label:'Reintentos',    type:'number' },
    ]
  },
  {
    key: 'entradas', label: 'Entradas digitales',
    vars: [
      { k:'tele/cistern_ok',        label:'Cisterna',       type:'digital' },
      { k:'tele/tank_demand',       label:'Demanda tanque', type:'digital' },
      { k:'tele/pressure_ok',       label:'Presión OK',     type:'digital' },
      { k:'tele/high_pressure_ok',  label:'P. alta OK',     type:'digital' },
      { k:'tele/leak_ok',           label:'Sin pérdida',    type:'digital' },
      { k:'tele/door_ok',           label:'Puerta OK',      type:'digital' },
    ]
  },
  {
    key: 'salidas', label: 'Salidas digitales',
    vars: [
      { k:'tele/bomba_baja',    label:'Bomba baja',     type:'digital' },
