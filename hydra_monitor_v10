<script>
// ═══════════════════════════════════════════════════════════
// CLIENT CODES — editá esto para cada cliente
// ═══════════════════════════════════════════════════════════
// ── CLIENT CODES — cargados desde clients.json (mismo directorio) ──
// Si no se puede cargar el JSON, se usa el fallback hardcodeado abajo.
let CLIENT_CODES = {};

async function loadClientCodes() {
  try {
    const resp = await fetch('./clients.json');
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    CLIENT_CODES = await resp.json();
    console.log('[Hydra] clients.json cargado:', Object.keys(CLIENT_CODES));
    const ok = document.getElementById('jsonOk');
    if (ok) { ok.style.display = 'block'; ok.textContent = '✓ Configuración cargada — ' + Object.keys(CLIENT_CODES).length + ' código(s)'; }
  } catch(e) {
    console.warn('[Hydra] No se pudo cargar clients.json:', e.message);
    // Show warning on login screen
    const hint = document.getElementById('jsonHint');
    if (hint) hint.style.display = 'block';
    // Fallback vacío — el usuario verá "Código inválido" si el JSON no carga
    CLIENT_CODES = {};
  }
}

// ═══════════════════════════════════════════════════════════
// TOPIC LABELS — structure matches official guide sections
// ═══════════════════════════════════════════════════════════

// SECTIONS define the fixed dashboard layout per the guide.
// Every variable listed here will appear in the dashboard —
// with its value if received, dimmed/empty if not yet received.
const SECTIONS = [
  {
    key: 'estado', label: 'Estado del equipo',
    vars: [
      { k:'stat/run',        label:'Produciendo',   type:'digital' },
      { k:'stat/status',     label:'Estado',        type:'text' },
