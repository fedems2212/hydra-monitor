<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#080d1a">
<title>Hydra Monitor Prueba 1</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/paho-mqtt/1.1.0/paho-mqtt.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<!-- PWA: permite instalar como app en el homescreen -->
<link rel="manifest" id="pwaManifest">
<script>
// Generate inline manifest with current URL so it works from any host
(function() {
  const urlCode = new URLSearchParams(location.search).get('code') || '';
  const startUrl = location.pathname + (urlCode ? '?code=' + urlCode : '');
  const manifest = {
    name: 'Hydra Monitor' + (urlCode ? ' — ' + urlCode : ''),
    short_name: 'Hydra',
    description: 'Monitor de equipos de tratamiento de agua',
    start_url: startUrl,
    display: 'standalone',
    background_color: '#080d1a',
    theme_color: '#080d1a',
    orientation: 'portrait-primary',
    icons: [
      { src: 'data:image/svg+xml,' + encodeURIComponent(`
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192">
          <rect width="192" height="192" rx="38" fill="#080d1a"/>
          <rect width="192" height="192" rx="38" fill="url(#g)"/>
          <defs>
            <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#0e1525"/>
              <stop offset="100%" stop-color="#1a2235"/>
            </linearGradient>
          </defs>
          <circle cx="96" cy="78" r="32" fill="none" stroke="#00d4ff" stroke-width="5"/>
          <circle cx="96" cy="78" r="18" fill="#00d4ff" opacity=".15"/>
          <path d="M96 46 Q110 62 96 78 Q82 62 96 46Z" fill="#00d4ff"/>
          <rect x="60" y="118" width="72" height="4" rx="2" fill="#1e2d45"/>
          <rect x="60" y="118" width="48" height="4" rx="2" fill="#00d4ff"/>
          <rect x="60" y="130" width="72" height="4" rx="2" fill="#1e2d45"/>
          <rect x="60" y="130" width="30" height="4" rx="2" fill="#00e676"/>
          <rect x="60" y="142" width="72" height="4" rx="2" fill="#1e2d45"/>
          <rect x="60" y="142" width="55" height="4" rx="2" fill="#ffab40"/>
        </svg>`),
        sizes: '192x192', type: 'image/svg+xml', purpose: 'any maskable'
      }
    ]
  };
  const blob = new Blob([JSON.stringify(manifest)], {type:'application/json'});
  document.getElementById('pwaManifest').href = URL.createObjectURL(blob);
})();
</script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap');

:root {
  --bg:       #080d1a;
  --bg2:      #0e1525;
  --bg3:      #151f33;
  --bg4:      #1c2840;
  --border:   #1e2d45;
  --border2:  #263550;
  --accent:   #00d4ff;
  --accentd:  #0088cc;
  --green:    #00e676;
  --greend:   #00b248;
  --red:      #ff3d57;
  --redd:     #cc1f35;
  --orange:   #ffab40;
  --yellow:   #ffd740;
  --purple:   #b388ff;
  --text:     #e2ecff;
  --text2:    #7a9cc4;
  --text3:    #3d5470;
  --font:     'DM Sans', system-ui, sans-serif;
  --mono:     'JetBrains Mono', monospace;
  --r:        10px;
  --r2:       7px;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html { height: 100%; }
body { background: var(--bg); color: var(--text); font-family: var(--font); min-height: 100dvh; overflow-x: hidden; }

/* Dot grid bg */
body::before {
  content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background-image: radial-gradient(circle, rgba(0,180,255,0.07) 1px, transparent 1px);
  background-size: 28px 28px;
}

/* ══ TOPBAR ══════════════════════════════════════════════════ */
.topbar {
  position: sticky; top: 0; z-index: 200;
  background: rgba(8,13,26,0.9); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  height: 52px; padding: 0 14px;
  display: flex; align-items: center; gap: 10px;
}
.logo { font-family: var(--mono); font-size: 14px; color: var(--accent); letter-spacing:.06em; flex-shrink:0; }
.logo em { color: var(--text3); font-style: normal; }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
.conn-badge {
  display: flex; align-items: center; gap: 5px;
  font-size: 10px; font-weight: 600; letter-spacing:.06em;
  padding: 4px 10px; border-radius: 20px;
  background: rgba(255,61,87,0.12); border: 1px solid rgba(255,61,87,0.25);
  color: var(--red); transition: all .3s;
}
.conn-badge.on { background: rgba(0,230,118,0.1); border-color: rgba(0,230,118,.25); color: var(--green); }
.conn-badge.ing { background: rgba(255,171,64,0.1); border-color: rgba(255,171,64,.25); color: var(--orange); animation: blink 1s infinite; }
.conn-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.back-btn {
  background: var(--bg3); border: 1px solid var(--border); border-radius: 7px;
  color: var(--text2); font-size: 12px; padding: 5px 12px; cursor: pointer;
  display: none; align-items: center; gap: 5px;
}
.back-btn.vis { display: flex; }

/* ══ SCREENS ═════════════════════════════════════════════════ */
.screen { display: none; position: relative; z-index: 1; padding: 12px 12px 80px; animation: screenIn .22s ease both; }
.screen.active { display: block; }
@keyframes screenIn { from{opacity:0;transform:translateX(18px)} to{opacity:1;transform:translateX(0)} }
@keyframes screenBack { from{opacity:0;transform:translateX(-18px)} to{opacity:1;transform:translateX(0)} }

/* ══ LOGIN SCREEN ════════════════════════════════════════════ */
#screenLogin {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: calc(100dvh - 52px);
  padding: 24px;
}
.login-card {
  width: 100%; max-width: 360px;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--r); padding: 28px 24px;
  box-shadow: 0 24px 64px rgba(0,0,0,.5);
}
.login-logo { font-family: var(--mono); font-size: 22px; color: var(--accent); margin-bottom: 4px; }
.login-sub { font-size: 12px; color: var(--text3); margin-bottom: 24px; }
.field { margin-bottom: 14px; }
.field label { display: block; font-size: 10px; font-weight: 600; color: var(--text3); letter-spacing:.1em; text-transform: uppercase; margin-bottom: 5px; }
.field input {
  width: 100%; background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--r2); padding: 11px 14px; color: var(--text);
  font-size: 14px; font-family: var(--mono); outline: none;
  transition: border-color .2s;
}
.field input:focus { border-color: var(--accentd); }
.field input::placeholder { color: var(--text3); }
.login-btn {
  width: 100%; padding: 13px; background: var(--accentd);
  border: none; border-radius: var(--r2); color: #fff;
  font-size: 14px; font-weight: 700; cursor: pointer;
  letter-spacing:.04em; transition: all .2s; margin-top: 4px;
}
.login-btn:hover { background: var(--accent); }
.login-btn:active { transform: scale(.98); }
.login-err { font-size: 12px; color: var(--red); margin-top: 10px; display: none; }
.login-mode-toggle {
  text-align: center; margin-top: 16px; font-size: 11px; color: var(--text3);
}
.login-mode-toggle a { color: var(--accent); cursor: pointer; text-decoration: none; }

/* Tech connect fields */
#techFields { display: none; }
.field-row { display: flex; gap: 10px; }
.field-row .field { flex: 1; }
.field-row .field.sm { flex: 0 0 80px; }

/* ══ CLIENTS SCREEN ══════════════════════════════════════════ */
.screen-title { font-size: 11px; font-weight: 700; color: var(--text3); letter-spacing:.1em; text-transform: uppercase; margin-bottom: 12px; }

.client-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--r); margin-bottom: 10px;
  cursor: pointer; transition: border-color .2s, transform .15s;
  overflow: hidden; animation: fadeUp .3s ease both;
}
.client-card:hover { border-color: var(--border2); }
.client-card:active { transform: scale(.99); }
.client-header { padding: 14px 16px; display: flex; align-items: center; gap: 12px; }
.client-icon {
  width: 40px; height: 40px; border-radius: 9px;
  background: linear-gradient(135deg, var(--accentd), #005588);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.client-info { flex: 1; min-width: 0; }
.client-name { font-size: 15px; font-weight: 600; }
.client-meta { font-size: 11px; color: var(--text2); margin-top: 2px; font-family: var(--mono); }
.client-stats { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; padding: 0 16px 14px; }
.client-stat-chip {
  font-size: 10px; font-family: var(--mono); padding: 3px 8px;
  border-radius: 5px; background: var(--bg3); border: 1px solid var(--border);
  color: var(--text2);
}
.client-stat-chip.alarm { border-color: rgba(255,61,87,.3); color: var(--red); background: rgba(255,61,87,.08); }
.client-stat-chip.online { border-color: rgba(0,230,118,.3); color: var(--green); }

/* ══ DEVICES SCREEN ══════════════════════════════════════════ */
.device-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--r); margin-bottom: 10px;
  cursor: pointer; transition: border-color .2s;
  overflow: hidden; animation: fadeUp .25s ease both;
}
.device-card:hover { border-color: var(--border2); }
.device-header { padding: 12px 14px; display: flex; align-items: center; gap: 10px; }
.state-badge {
  padding: 3px 9px; border-radius: 5px; font-size: 9px;
  font-weight: 700; letter-spacing:.08em; font-family: var(--mono); flex-shrink: 0;
}
.s-RUNNING    { background: rgba(0,230,118,.15); color: var(--green); border: 1px solid rgba(0,230,118,.3); }
.s-IDLE       { background: rgba(100,130,180,.1); color: var(--text2); border: 1px solid var(--border); }
.s-STARTING   { background: rgba(255,171,64,.15); color: var(--orange); border: 1px solid rgba(255,171,64,.3); }
.s-OFFLINE    { background: rgba(255,61,87,.15); color: var(--red); border: 1px solid rgba(255,61,87,.3); }
.s-LEARNING   { background: rgba(0,212,255,.15); color: var(--accent); border: 1px solid rgba(0,212,255,.3); }
.s-WAIT_CISTERN { background: rgba(255,215,64,.12); color: var(--yellow); border: 1px solid rgba(255,215,64,.3); }
.s-default    { background: rgba(100,130,180,.1); color: var(--text2); border: 1px solid var(--border); }

.device-name { flex: 1; min-width: 0; }
.device-id { font-size: 14px; font-weight: 600; }
.device-path { font-size: 10px; color: var(--text3); font-family: var(--mono); margin-top: 1px; }
.alarm-pill {
  font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px;
  background: rgba(255,61,87,.15); border: 1px solid rgba(255,61,87,.3);
  color: var(--red); animation: blink 2s infinite; flex-shrink:0;
}
.chevron { color: var(--text3); font-size: 10px; transition: transform .25s; flex-shrink:0; }
.device-card.open .chevron { transform: rotate(180deg); }

/* ══ DASHBOARD ═══════════════════════════════════════════════ */
.device-body { display: none; padding: 0 14px 14px; }
.device-card.open .device-body { display: block; }

/* Section header */
.sec-hdr {
  display: flex; align-items: center; gap: 8px;
  font-size: 9px; font-weight: 700; color: var(--text3);
  letter-spacing: .1em; text-transform: uppercase;
  margin: 14px 0 8px;
}
.sec-hdr::after { content: ''; flex:1; height:1px; background: var(--border); }

/* Signal tiles grid */
.tiles { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 7px; }

.tile {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--r2); padding: 10px 12px;
  position: relative; overflow: hidden;
  transition: border-color .2s;
}
.tile::before {
  content: ''; position: absolute;
  left: 0; top: 0; bottom: 0; width: 3px;
  background: var(--text3); border-radius: 3px 0 0 3px;
  transition: background .3s;
}
.tile.t-on::before   { background: var(--green); }
.tile.t-off::before  { background: var(--text3); }
.tile.t-alarm::before{ background: var(--red); }
.tile.t-analog::before{ background: var(--accentd); }
.tile.t-text::before { background: var(--purple); }

.tile-label {
  font-size: 9px; font-weight: 600; color: var(--text3);
  text-transform: uppercase; letter-spacing: .07em; margin-bottom: 6px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.tile-val {
  font-family: var(--mono); font-size: 18px; font-weight: 500;
  color: var(--text); line-height: 1; display: flex; align-items: baseline; gap: 3px;
}
.tile-val.big { font-size: 22px; }
.tile-unit { font-size: 10px; color: var(--text3); }

/* Digital indicator */
.dig-row { display: flex; align-items: center; gap: 7px; }
.dig-led {
  width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  transition: background .3s, box-shadow .3s;
}
.led-on  { background: var(--green); box-shadow: 0 0 8px var(--green); }
.led-off { background: var(--text3); }
.led-alarm { background: var(--red); box-shadow: 0 0 8px var(--red); animation: blink 1.5s infinite; }
.dig-label { font-size: 13px; font-weight: 500; }
.dig-label.on  { color: var(--green); }
.dig-label.off { color: var(--text3); }
.dig-label.alarm { color: var(--red); }

/* Alarms in dashboard */
.alarm-list { display: flex; flex-direction: column; gap: 5px; margin-top: 4px; }
.alarm-row {
  display: flex; align-items: center; gap: 8px; padding: 7px 10px;
  background: rgba(255,61,87,.07); border: 1px solid rgba(255,61,87,.2);
  border-radius: var(--r2); font-size: 12px;
}
.alarm-key { font-family: var(--mono); color: var(--red); flex: 1; font-size: 11px; }
.alarm-dur { font-size: 10px; color: var(--text3); }
.no-alarm { font-size: 12px; color: var(--green); padding: 6px 0; display: flex; align-items:center; gap:6px; }

/* Stats bar */
.stats-bar { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 2px; }
.stat-chip {
  font-size: 10px; font-family: var(--mono); padding: 3px 9px;
  border-radius: 5px; background: var(--bg3); border: 1px solid var(--border); color: var(--text2);
}
.stat-chip b { color: var(--text); }

/* AI Diagnosis box */
.diag-box {
  background: rgba(0,136,204,.07); border: 1px solid rgba(0,136,204,.2);
  border-radius: var(--r2); padding: 12px;
}
.diag-header { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; }
.diag-title { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
.diag-badge {
  font-size: 9px; font-family: var(--mono); font-weight: 700;
  padding: 2px 7px; border-radius: 4px; flex-shrink: 0;
}
.db-alarm { background: rgba(255,61,87,.2); color: var(--red); }
.db-warn  { background: rgba(255,171,64,.2); color: var(--orange); }
.db-info  { background: rgba(0,212,255,.15); color: var(--accent); }
.diag-ev  { font-size: 11px; color: var(--text2); padding: 1px 0 1px 10px; position: relative; }
.diag-ev::before { content: '·'; position: absolute; left:2px; color: var(--accentd); }
.diag-act { font-size: 11px; color: var(--text2); padding: 1px 0 1px 12px; position: relative; }
.diag-act::before { content: '→'; position: absolute; left:0; font-size:9px; color: var(--green); top:3px; }
.diag-sep { margin: 5px 0; border: none; border-top: 1px solid var(--border); }

/* ══ CHARTS ══════════════════════════════════════════════════ */
.chart-wrap {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--r2); padding: 10px; margin-bottom: 7px;
}
.chart-title { font-size: 10px; font-weight: 600; color: var(--text2); margin-bottom: 6px; display: flex; justify-content: space-between; }
.chart-title span { font-family: var(--mono); color: var(--accent); }
.chart-canvas-wrap { position: relative; height: 100px; }

/* ══ BOTTOM NAV ══════════════════════════════════════════════ */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
  background: rgba(8,13,26,.95); backdrop-filter: blur(12px);
  border-top: 1px solid var(--border);
  display: none; padding-bottom: env(safe-area-inset-bottom,0px);
}
.bottom-nav.vis { display: flex; }
.nav-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 9px 4px; gap: 3px; background: none; border: none;
  color: var(--text3); font-size: 9px; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase; cursor: pointer; transition: color .2s;
}
.nav-btn svg { width: 19px; height: 19px; }
.nav-btn.active { color: var(--accent); }

/* ══ RAW TOPICS (tech) ═══════════════════════════════════════ */
.raw-toggle { font-size: 11px; color: var(--text3); cursor: pointer; user-select:none; padding: 4px 0; }
.raw-toggle:hover { color: var(--text2); }
.raw-table { display: none; }
.raw-table.vis { display: block; }
.raw-row { display: flex; font-size: 10px; font-family: var(--mono); padding: 2px 4px; gap: 8px; border-radius: 3px; }
.raw-row:nth-child(odd) { background: rgba(255,255,255,.02); }
.raw-k { color: var(--text3); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.raw-v { color: var(--text); max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ══ EMPTY & LOADING ═════════════════════════════════════════ */
.empty { text-align: center; padding: 50px 20px; color: var(--text3); }
.empty-icon { font-size: 36px; margin-bottom: 10px; }
.empty h3 { font-size: 13px; color: var(--text2); margin-bottom: 6px; }
.empty p { font-size: 11px; line-height: 1.7; }

/* ══ ANIMATIONS ══════════════════════════════════════════════ */
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }
@keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
@keyframes spin { to{transform:rotate(360deg)} }
@keyframes flash { 0%{background:rgba(0,212,255,.15)} 100%{background:transparent} }

/* ══ RESPONSIVE ══════════════════════════════════════════════ */
@media (min-width:560px) {
  #screenClients, #screenDevices, #screenDashboard { max-width: 640px; margin: 0 auto; }
}
</style>
</head>
<body>

<!-- ══ TOPBAR ══════════════════════════════════════════════ -->
<div class="topbar" id="appTopbar" style="display:none">
  <div class="logo">HYDRA<em>/monitor</em></div>
  <button class="back-btn" id="btnBack" onclick="goBack()">← Volver</button>
  <div class="topbar-right">
    <div class="conn-badge" id="connBadge" style="display:none">
      <div class="conn-dot"></div>
      <span id="connLabel">desconectado</span>
    </div>
  </div>
</div>

<!-- LOGIN TOPBAR -->
<div class="topbar" id="loginTopbar">
  <div class="logo">HYDRA<em>/monitor</em></div>
</div>

<!-- ══ SCREENS ═════════════════════════════════════════════ -->

<!-- LOGIN -->
<div class="screen" id="screenLogin">
  <div class="login-card">
    <div class="login-logo">// HYDRA</div>
    <div class="login-sub">Monitor de equipos en tiempo real</div>

    <!-- CLIENT MODE (default) -->
    <div id="clientLoginFields">
      <div class="field">
        <label>Código de acceso</label>
        <input id="accessCode" type="text" placeholder="ej: ACME2025" autocomplete="off"
               style="text-transform:uppercase; letter-spacing:.1em; font-size:18px; text-align:center"
               oninput="this.value=this.value.toUpperCase()">
      </div>
    </div>

    <!-- TECH MODE -->
    <div id="techFields">
      <div class="field-row">
        <div class="field"><label>Broker host</label><input id="tHost" placeholder="xxx.hivemq.cloud"></div>
        <div class="field sm"><label>Puerto</label><input id="tPort" type="number" value="8884"></div>
      </div>
      <div class="field-row">
        <div class="field"><label>Usuario</label><input id="tUser" placeholder="usuario"></div>
        <div class="field"><label>Contraseña</label><input id="tPass" type="password" placeholder="••••"></div>
      </div>
      <div class="field">
        <label>Equipo (namespace/client/device)</label>
        <input id="tTopic" placeholder="agua/vacoto/rom_base_01"
               style="font-family:var(--mono);font-size:13px">
        <div style="font-size:10px;color:var(--text3);margin-top:4px">
          Ingresá el path completo del equipo
        </div>
      </div>
    </div>

    <button class="login-btn" onclick="doLogin()">Ingresar</button>
    <div class="login-err" id="loginErr"></div>

    <div id="jsonHint" style="display:none;margin-top:12px;padding:10px 12px;background:rgba(255,61,87,.1);border:1px solid rgba(255,61,87,.3);border-radius:8px;font-size:11px;color:#ff6b7a">
      ⚠ No se pudo cargar la configuración (clients.json).<br>
      Verificá que el archivo existe en el repositorio y que GitHub Pages está activo.
    </div>
